{
  "info": {
    "name": "ECommerceHub API",
    "description": "ECommerceHub mikroservis mimarisi için kapsamlı API koleksiyonu.\n\nKullanım:\n1. Environment değişkenlerini ayarla: baseUrl, accessToken\n2. Auth/Login isteği çalıştır → token otomatik kaydedilir\n3. Diğer istekleri çalıştır",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "productId", "value": "1", "type": "string" },
    { "key": "orderId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "description": "JWT kimlik doğrulama — register, login, token yenileme, logout",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ahmet\",\n  \"lastName\": \"Yılmaz\",\n  \"email\": \"ahmet@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('accessToken var', () => pm.expect(json.data.accessToken).to.be.a('string'));",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ecommerce.com\",\n  \"password\": \"Admin123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Token alındı', () => pm.expect(json.data.accessToken).to.be.a('string'));",
                  "// Token'ı koleksiyon değişkenine kaydet — tüm istekler bu token'ı kullanır",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "console.log('Token kaydedildi. Süre:', json.data.expiresIn + 'ms');"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh-token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('accessToken', '');",
                  "pm.collectionVariables.set('refreshToken', '');"
                ]
              }
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Product Service",
      "description": "Ürün CRUD, Elasticsearch arama, stok yönetimi",
      "item": [
        {
          "name": "Get All Products (Paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=0&size=10&sortBy=name&sortDir=ASC",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sortBy", "value": "name" },
                { "key": "sortDir", "value": "ASC" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Sayfalı yanıt', () => {",
                  "  pm.expect(json.data.content).to.be.an('array');",
                  "  pm.expect(json.data.totalElements).to.be.a('number');",
                  "});",
                  "if (json.data.content.length > 0) {",
                  "  pm.collectionVariables.set('productId', json.data.content[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Ürün ID doğru', () => pm.expect(json.data.id).to.equal(parseInt(pm.collectionVariables.get('productId'))));"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Products (Elasticsearch)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/search?query=laptop&page=0&size=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "search"],
              "query": [
                { "key": "query", "value": "laptop" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "5" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Arama sonucu döndü', () => pm.expect(pm.response.json().data.content).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Products by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/category/1?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "category", "1"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Laptop\",\n  \"description\": \"Yüksek performanslı test laptopu\",\n  \"price\": 15999.99,\n  \"stockQuantity\": 50,\n  \"sku\": \"LAP-TEST-001\",\n  \"categoryId\": 1\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('productId', json.data.id);",
                  "pm.test('Ürün oluşturuldu', () => pm.expect(json.data.name).to.equal('Test Laptop'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Laptop Güncellenmiş\",\n  \"description\": \"Güncellenmiş açıklama\",\n  \"price\": 13999.99,\n  \"stockQuantity\": 45,\n  \"sku\": \"LAP-TEST-001\",\n  \"categoryId\": 1\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/products/{{productId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"]
              }
            }
          ]
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Kategori\",\n  \"description\": \"Test kategorisi\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Order Service",
      "description": "Sipariş oluşturma (Saga), listeleme, iptal",
      "item": [
        {
          "name": "Create Order (Saga başlatır)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"Atatürk Cad. No:1 Kadıköy İstanbul 34710\",\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2\n    },\n    {\n      \"productId\": 2,\n      \"quantity\": 1\n    }\n  ]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Sipariş PENDING durumunda', () => pm.expect(json.data.status).to.equal('PENDING'));",
                  "pm.test('Sipariş numarası var', () => pm.expect(json.data.orderNumber).to.be.a('string'));",
                  "pm.collectionVariables.set('orderId', json.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders/my-orders?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "my-orders"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Sayfalı sipariş listesi', () => pm.expect(pm.response.json().data.content).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/orders/{{orderId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Sipariş kalemi var', () => pm.expect(pm.response.json().data.items).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/orders/{{orderId}}/cancel"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Durum CANCELLED', () => pm.expect(pm.response.json().data.status).to.equal('CANCELLED'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/orders?page=0&size=20&status=PENDING",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "status", "value": "PENDING" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Actuator & Health",
      "description": "Servis sağlık kontrolü ve metrikler",
      "item": [
        {
          "name": "API Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('UP durumunda', () => pm.expect(pm.response.json().status).to.equal('UP'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Auth Service Health (Direct)",
          "request": {
            "method": "GET",
            "url": "http://localhost:8081/actuator/health"
          }
        },
        {
          "name": "Product Service Health (Direct)",
          "request": {
            "method": "GET",
            "url": "http://localhost:8082/actuator/health"
          }
        },
        {
          "name": "Order Service Health (Direct)",
          "request": {
            "method": "GET",
            "url": "http://localhost:8083/actuator/health"
          }
        },
        {
          "name": "Consul Members",
          "request": {
            "method": "GET",
            "url": "http://localhost:8500/v1/catalog/services"
          }
        },
        {
          "name": "Circuit Breaker State",
          "request": {
            "method": "GET",
            "url": "http://localhost:8083/actuator/circuitbreakers"
          }
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  }
}
