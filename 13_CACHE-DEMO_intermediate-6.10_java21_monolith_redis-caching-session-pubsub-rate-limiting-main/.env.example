# ==================== ÖRNEK ORTAM DEĞİŞKENLERİ ====================
# Bu dosyayı kopyalayıp .env olarak adlandırın:
#   cp .env.example .env
# Ardından gerçek değerleri doldurun.
# .env dosyasını asla Git'e commit'lemeyin!

# ==================== POSTGRESQL AYARLARI ====================
# Veritabanı sunucu adresi (Docker'da servis adı kullanılır)
DB_HOST=db
# PostgreSQL port numarası
DB_PORT=5432
# Oluşturulacak veritabanı adı
DB_NAME=redisdb
# Veritabanı kullanıcı adı
DB_USERNAME=postgres
# Veritabanı şifresi (güvenli bir şifre belirleyin)
DB_PASSWORD=postgres123

# ==================== REDIS AYARLARI ====================
# Redis sunucu adresi (Docker'da servis adı kullanılır)
REDIS_HOST=redis
# Redis port numarası
REDIS_PORT=6379
# Redis şifresi (boş bırakırsanız şifresiz bağlanır)
REDIS_PASSWORD=

# ==================== JWT AYARLARI ====================
# JWT imzalama anahtarı (en az 256-bit = 32 karakter olmalı)
JWT_SECRET=buCokGizliJwtAnahtar1234567890123456789012345678
# Access token geçerlilik süresi (saniye) - 15 dakika
JWT_ACCESS_EXPIRY=900
# Refresh token geçerlilik süresi (saniye) - 7 gün
JWT_REFRESH_EXPIRY=604800

# ==================== UYGULAMA AYARLARI ====================
# Spring Boot uygulama portu
SERVER_PORT=8080

# ==================== PGADMIN AYARLARI ====================
# pgAdmin web arayüzü giriş e-posta
PGADMIN_EMAIL=admin@admin.com
# pgAdmin web arayüzü giriş şifresi
PGADMIN_PASSWORD=admin123
