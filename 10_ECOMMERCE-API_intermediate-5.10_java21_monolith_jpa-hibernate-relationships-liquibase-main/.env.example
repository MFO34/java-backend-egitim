# =============================================================
# E-TİCARET API — Ortam Değişkenleri Şablonu
# =============================================================
# Bu dosyayı kopyalayarak .env oluştur:
#   cp .env.example .env
# Sonra .env içindeki değerleri değiştir.
# .env dosyası .gitignore'dadır — şifreler GitHub'a gitmez!
# =============================================================

# ----- PostgreSQL Veritabanı -----
DB_NAME=eticaret_db           # Veritabanı adı
DB_USER=eticaret_user         # Kullanıcı adı
DB_PASSWORD=eticaret_pass     # Şifre (güçlü bir şifre koy!)
DB_PORT=5432                  # PostgreSQL portu

# ----- Spring Boot Uygulama -----
APP_PORT=8080                 # API portu
SPRING_PROFILES_ACTIVE=dev    # Aktif profil: dev veya prod

# ----- pgAdmin (PostgreSQL Yönetim Arayüzü) -----
PGADMIN_EMAIL=admin@eticaret.com   # pgAdmin giriş e-postası
PGADMIN_PASSWORD=admin123          # pgAdmin şifresi
PGADMIN_PORT=5050                  # pgAdmin web arayüzü portu
