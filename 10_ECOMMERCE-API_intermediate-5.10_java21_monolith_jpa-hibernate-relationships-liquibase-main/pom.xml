<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!--
        SPRING BOOT PARENT BOM (Bill of Materials):
        Tüm bağımlılık versiyonlarını otomatik yönetir.
        Biz sadece artifact id yazarız, versiyon çakışması olmaz.
    -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.3.5</version>
        <relativePath/>
    </parent>

    <!-- Proje kimlik bilgileri -->
    <groupId>com.eticaret</groupId>
    <artifactId>eticaret-api</artifactId>
    <version>1.0.0</version>
    <name>E-Ticaret Ürün ve Sipariş Yönetim API</name>
    <description>JPA &amp; Hibernate tüm ilişkiler, Liquibase, Specification, Java 21</description>

    <properties>
        <!-- Java 21 — Virtual Threads, Sealed Classes, Records, Pattern Matching -->
        <java.version>21</java.version>
        <!-- MapStruct — compile-time DTO mapper (reflection yok → hızlı) -->
        <mapstruct.version>1.5.5.Final</mapstruct.version>
        <!-- Lombok — boilerplate azaltır: @Data, @Builder, @Slf4j -->
        <lombok.version>1.18.32</lombok.version>
        <!-- SpringDoc — Swagger UI / OpenAPI 3 -->
        <springdoc.version>2.3.0</springdoc.version>
    </properties>

    <dependencies>

        <!-- ===== SPRING BOOT STARTER'LAR ===== -->

        <!--
            spring-boot-starter-web:
            - Spring MVC (REST API için @RestController)
            - Gömülü Tomcat (port 8080)
            - Jackson (JSON serileştirme)
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!--
            spring-boot-starter-data-jpa:
            - Spring Data JPA (JpaRepository, @Query)
            - Hibernate 6.x (JPA implementasyonu)
            - HikariCP (connection pool)
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>

        <!--
            spring-boot-starter-validation:
            - Jakarta Bean Validation 3.0
            - @NotBlank, @Size, @Email, @Min, @Max
            - @Valid ile controller'da otomatik kontrol
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!--
            spring-boot-starter-actuator:
            - /actuator/health — sağlık kontrolü
            - /actuator/metrics — metrikler
            - Docker healthcheck için kullanılır
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- ===== VERİTABANI ===== -->

        <!--
            PostgreSQL JDBC Driver:
            - runtime scope: sadece çalışma zamanında gerekli
            - Derleme için Spring Data JPA API'si yeterli
        -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!--
            Liquibase Core:
            - Veritabanı migration aracı
            - XML/YAML/SQL ile değişiklik takibi
            - Uygulama başlarken otomatik çalışır
            - DATABASECHANGELOG tablosu ile sürüm kontrolü
        -->
        <dependency>
            <groupId>org.liquibase</groupId>
            <artifactId>liquibase-core</artifactId>
        </dependency>

        <!-- ===== YARDIMCI KÜTÜPHANELER ===== -->

        <!--
            Lombok:
            - @Data → getter/setter/equals/hashCode/toString üretir
            - @Builder → builder pattern
            - @Slf4j → log değişkeni üretir
            - @NoArgsConstructor, @AllArgsConstructor
            optional=true: son JAR'a dahil edilmez
        -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>${lombok.version}</version>
            <optional>true</optional>
        </dependency>

        <!--
            MapStruct:
            - Compile-time DTO ↔ Entity mapper
            - Reflection kullanmaz → runtime overhead yok
            - @Mapper anotasyonu ile interface yeterli
        -->
        <dependency>
            <groupId>org.mapstruct</groupId>
            <artifactId>mapstruct</artifactId>
            <version>${mapstruct.version}</version>
        </dependency>

        <!--
            SpringDoc OpenAPI:
            - Swagger UI otomatik üretir
            - @Tag, @Operation, @ApiResponse anotasyonları
            - http://localhost:8080/swagger-ui.html
        -->
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
            <version>${springdoc.version}</version>
        </dependency>

        <!-- ===== TEST ===== -->

        <!--
            spring-boot-starter-test:
            - JUnit 5 (test framework)
            - Mockito (mock nesneler)
            - AssertJ (fluent assertions)
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- H2 — test için in-memory veritabanı (Liquibase ile uyumlu) -->
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <build>
        <plugins>

            <!--
                Spring Boot Maven Plugin:
                - mvn spring-boot:run → uygulamayı çalıştır
                - mvn package → executable JAR oluştur
                - Lombok ve MapStruct için exclude yapılandırması
            -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <!-- Lombok opsiyonel bağımlılığı JAR'dan çıkar -->
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>

            <!--
                Maven Compiler Plugin:
                - Java 21 + enable-preview (Sealed Classes preview ozellikleri)
                - annotationProcessorPaths: Lombok ONCE, sonra MapStruct
                  (MapStruct, Lombok'un urettigi kodu gorebilmeli - sira onemli!)
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                    <compilerArgs>
                        <arg>--enable-preview</arg>
                    </compilerArgs>
                    <annotationProcessorPaths>
                        <!-- 1. Lombok önce çalışır → @Builder, @Data kodu üretir -->
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>${lombok.version}</version>
                        </path>
                        <!-- 2. MapStruct sonra çalışır → Lombok kodunu görür -->
                        <path>
                            <groupId>org.mapstruct</groupId>
                            <artifactId>mapstruct-processor</artifactId>
                            <version>${mapstruct.version}</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>

        </plugins>
    </build>

    <!--
        Maven Profilleri:
        -Pdev  → geliştirme (dev DB, debug log)
        -Pprod → üretim (prod DB, minimal log)
    -->
    <profiles>
        <profile>
            <id>dev</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <properties>
                <spring.profiles.active>dev</spring.profiles.active>
            </properties>
        </profile>
        <profile>
            <id>prod</id>
            <properties>
                <spring.profiles.active>prod</spring.profiles.active>
            </properties>
        </profile>
    </profiles>

</project>
