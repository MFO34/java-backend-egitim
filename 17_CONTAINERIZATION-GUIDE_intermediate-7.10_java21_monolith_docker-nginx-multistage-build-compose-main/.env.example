# ==============================================================================
# ÖRNEK ORTAM DEĞİŞKENLERİ DOSYASI
# ==============================================================================
# Kullanım:
#   cp .env.example .env
#   nano .env  # Gerçek değerleri gir
#
# UYARI: .env dosyasını asla Git'e commit'leme!
#        .gitignore'a eklendiğinden emin ol.
# ==============================================================================

# ── UYGULAMA AYARLARI ────────────────────────────────────────────────────────
# Uygulama sürümü (Docker imaj etiketleme için kullanılır)
APP_VERSION=1.0.0

# Spring aktif profili: default | dev | prod
SPRING_PROFILES_ACTIVE=default

# ── POSTGRESQL AYARLARI ──────────────────────────────────────────────────────
# Veritabanı adı
DB_NAME=dockerdb
# Veritabanı kullanıcı adı
DB_USERNAME=postgres
# Veritabanı şifresi - ÜRETİMDE GÜÇLÜ BİR ŞİFRE KULLAN!
DB_PASSWORD=postgres123
# PostgreSQL dışarıya açılacak port (host:container eşlemesi için)
DB_EXTERNAL_PORT=5432

# ── REDIS AYARLARI ───────────────────────────────────────────────────────────
# Redis şifresi (boş bırakılırsa şifresiz bağlanır)
# ÜRETİMDE MUTLAKA ŞİFRE EKLE!
REDIS_PASSWORD=
# Redis dışarıya açılacak port
REDIS_EXTERNAL_PORT=6379

# ── NGINX AYARLARI ───────────────────────────────────────────────────────────
# HTTP port
NGINX_HTTP_PORT=80
# HTTPS port (SSL sertifikası hazır olduğunda)
NGINX_HTTPS_PORT=443

# ── PGADMIN AYARLARI ─────────────────────────────────────────────────────────
# pgAdmin giriş e-postası
PGADMIN_EMAIL=admin@admin.com
# pgAdmin giriş şifresi
PGADMIN_PASSWORD=admin123
# pgAdmin web arayüzü portu
PGADMIN_PORT=5050

# ── REDIS COMMANDER AYARLARI ─────────────────────────────────────────────────
# Redis Commander web arayüzü portu
REDIS_COMMANDER_PORT=8083
