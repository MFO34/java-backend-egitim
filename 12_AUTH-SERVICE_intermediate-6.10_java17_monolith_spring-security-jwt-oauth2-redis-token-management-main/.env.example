# =============================================================
# AUTH SERVICE — Ortam Değişkenleri Şablonu
# =============================================================
# Kopyala: cp .env.example .env
# .env dosyası .gitignore'dadır — şifreler GitHub'a gitmez!
# =============================================================

# ----- PostgreSQL -----
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=auth_pass
DB_PORT=5432

# ----- Spring Boot -----
APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ----- JWT -----
# En az 256-bit (32 karakter) Base64 kodlu gizli anahtar
JWT_SECRET=bXlTdXBlclNlY3JldEtleUZvckpXVEF1dGhlbnRpY2F0aW9uMjAyNQ==
JWT_ACCESS_EXPIRATION_MS=900000       # 15 dakika
JWT_REFRESH_EXPIRATION_MS=604800000   # 7 gün

# ----- Google OAuth2 -----
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----- GitHub OAuth2 -----
# https://github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ----- Email (JavaMailSender) -----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password        # Gmail: App Password oluştur
MAIL_FROM=noreply@auth-service.com

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                        # Boş bırak → şifresiz

# ----- pgAdmin -----
PGADMIN_EMAIL=admin@auth.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# ----- Redis Commander -----
REDIS_COMMANDER_PORT=8081

# ----- OAuth2 Callback -----
# Frontend'in OAuth2 başarı/hata sonrası yönlendirileceği URL
OAUTH2_REDIRECT_SUCCESS_URI=http://localhost:3000/oauth2/callback
OAUTH2_REDIRECT_FAILURE_URI=http://localhost:3000/oauth2/error
